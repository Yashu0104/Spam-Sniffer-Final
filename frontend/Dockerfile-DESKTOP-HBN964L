FROM node:20-slim

WORKDIR /app

COPY package*.json ./

RUN npm install --omit=optional

COPY . .

# Create .env file from environment variables if they exist
RUN echo "VITE_REACT_APP_CLIENT_ID=${VITE_REACT_APP_CLIENT_ID:-your_google_client_id_here}" > .env && \
    echo "VITE_REACT_APP_API_KEY=${VITE_REACT_APP_API_KEY:-your_google_api_key_here}" >> .env && \
    echo "VITE_REACT_APP_SCOPES=${VITE_REACT_APP_SCOPES:-https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.modify}" >> .env

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
